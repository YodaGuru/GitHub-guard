{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "github-guard",
  "blocks": {
    "entry": "src/main.ts",
    "triggers": [
      "onPostCreate",
      "onCommentCreate",
      "onCommentUpdate"
    ]
  },
  "permissions": {
    "reddit": true,
    "http": {
      "domains": ["api.github.com"]
    }
  }
}